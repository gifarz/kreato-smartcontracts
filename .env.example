# Private key of the wallet that deploys the contract
# NEVER commit the real key — this is just the example
DEPLOYER_PRIVATE_KEY=0xyour_deployer_wallet_private_key

# RPC URLs
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Block explorer API keys (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# Report gas usage in tests
REPORT_GAS=false


NEXT_PUBLIC_KREATO_CONTRACT_SEPOLIA=0xd0cBE2B55D16f225Bb1eA2Fe6aC8258281794DbC  (if testnet)
NEXT_PUBLIC_KREATO_CONTRACT_ETH=0xd0cBE2B55D16f225Bb1eA2Fe6aC8258281794DbC      (if mainnet)
NEXT_PUBLIC_KREATO_CONTRACT_BASE=0xd0cBE2B55D16f225Bb1eA2Fe6aC8258281794DbC     (if base)